# Copy this to .env and fill in values before running docker compose up

# MySQL
MYSQL_ROOT_PASSWORD=lovely-fables-ginger-juice-banana-mango
MYSQL_DATABASE=snipeit
MYSQL_USER=snipeit
MYSQL_PASSWORD=ocean-deep-sea-diver-sunlight-river

# Snipe-IT app key — generate with: docker run --rm snipe/snipe-it php artisan key:generate --show
APP_KEY=base64:BkGGqa5+4DTRixl0wQsL6Vxb4kBClfQQbMt/kia+KCk=

# Snipe-IT public URL (used by the app itself for links/emails)
APP_URL=http://localhost:8080

# Timezone
TZ=Africa/Nairobi

# Snipe-IT API token — create in Snipe-IT after first setup: Profile → API Tokens
SNIPEIT_API_TOKEN=CHANGE_ME_AFTER_FIRST_LOGIN

# Kiosk settings
# How long (ms) of inactivity before showing the Finish button
KIOSK_FINISH_DELAY=5000
# How long (ms) of inactivity before auto-resetting the session
KIOSK_RESET_DELAY=15000
